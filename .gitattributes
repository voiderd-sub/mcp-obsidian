# Force LF line endings for all text files in this repo, both in the
# index and in checked-out working trees. Prevents CRLF noise on Windows
# clones and keeps GitHub diffs consistent.
* text=auto eol=lf

# Explicit LF for common text formats
*.py    text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf
*.lock  text eol=lf

# Binary catch-alls (don't normalize)
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
